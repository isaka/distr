---
import {Icon} from 'astro-icon/components';
import {parse} from 'node-html-parser';

export interface FAQItem {
  id?: string;
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQItem[];
  title?: string;
  subtitle?: string;
}

const {faqs, title = 'Frequently Asked Questions', subtitle} = Astro.props;

// Plain-text version of the answer for the FAQPage JSON-LD `text` field.
// Google's FAQ rich-result eligibility prefers plain text over HTML markup.
const htmlToPlainText = (html: string): string =>
  parse(html).text.replace(/\s+/g, ' ').trim();

const faqLdJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({question, answer}) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: htmlToPlainText(answer),
    },
  })),
}).replace(/</g, '\\u003c');
---

<script type="application/ld+json" is:inline set:html={faqLdJson} />

<section class="not-content py-16 md:py-24">
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">{title}</h2>
      {
        subtitle && (
          <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
            {subtitle}
          </p>
        )
      }
    </div>
    <div class="max-w-4xl mx-auto space-y-4">
      {
        faqs.map(faq => (
          <details
            class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm hover:shadow-md transition-shadow scroll-mt-24 group"
            id={faq.id}>
            <summary class="p-6 md:p-8 cursor-pointer list-none flex items-start gap-3">
              <Icon
                name="lucide:chevron-down"
                class="faq-chevron shrink-0 w-6 h-6 mt-1 text-gray-400 dark:text-gray-500 group-hover:text-accent-600 transition-all duration-200"
              />
              <h3 class="text-xl md:text-2xl font-semibold m-0 flex-1 min-w-0 text-gray-900 dark:text-white group-hover:text-accent-600 dark:group-hover:text-accent-600 transition-colors">
                {faq.question}
              </h3>
            </summary>
            <div class="px-6 md:px-8 pb-6 md:pb-8 pt-0">
              <div
                class="faq-answer prose prose-lg dark:prose-invert max-w-none prose-p:text-gray-600 dark:prose-p:text-gray-300 prose-p:leading-relaxed"
                set:html={faq.answer}
              />
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq-answer :global(p:first-child) {
    margin-top: 0;
  }

  .faq-answer :global(p:last-child) {
    margin-bottom: 0;
  }

  .faq-answer :global(br) {
    display: block;
    content: '';
    margin-top: 0.5em;
  }

  .faq-answer :global(a) {
    color: var(--color-accent-600);
    text-decoration: underline;
  }

  .faq-answer :global(a:hover) {
    color: var(--color-accent-900);
  }

  details summary::-webkit-details-marker {
    display: none;
  }

  details summary::marker {
    display: none;
  }

  :global(details[open] .faq-chevron) {
    transform: rotate(180deg);
  }
</style>
